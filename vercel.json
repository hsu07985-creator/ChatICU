{
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://chaticu-production-8060.up.railway.app/auth/:path*"
    },
    {
      "source": "/ai/:path*",
      "destination": "https://chaticu-production-8060.up.railway.app/ai/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://chaticu-production-8060.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://chaticu-production-8060.up.railway.app/health"
    },
    {
      "source": "/health/:path*",
      "destination": "https://chaticu-production-8060.up.railway.app/health/:path*"
    },
    {
      "source": "/team/:path*",
      "destination": "https://chaticu-production-8060.up.railway.app/team/:path*"
    },
    {
      "source": "/v2/:path*",
      "destination": "https://chaticu-production-8060.up.railway.app/v2/:path*"
    },
    {
      "source": "/record-templates",
      "destination": "https://chaticu-production-8060.up.railway.app/record-templates"
    },
    {
      "source": "/record-templates/:path*",
      "destination": "https://chaticu-production-8060.up.railway.app/record-templates/:path*"
    },
    {
      "source": "/patients",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/patients"
    },
    {
      "source": "/patients/:path*",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/patients/:path*"
    },
    {
      "source": "/dashboard",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/dashboard"
    },
    {
      "source": "/dashboard/:path*",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/dashboard/:path*"
    },
    {
      "source": "/admin",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/admin"
    },
    {
      "source": "/admin/:path*",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/admin/:path*"
    },
    {
      "source": "/pharmacy",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/pharmacy"
    },
    {
      "source": "/pharmacy/:path*",
      "has": [
        {
          "type": "header",
          "key": "x-request-id"
        }
      ],
      "destination": "https://chaticu-production-8060.up.railway.app/pharmacy/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "framework": "vite",
  "buildCommand": "npx vite build --force",
  "outputDirectory": "build",
  "installCommand": "npm install"
}
