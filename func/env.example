### Func 專用環境變數範例（Evidence RAG + Clinical Rules）

### 基本
HOST=0.0.0.0
PORT=8000
# /clinical/query intent=auto 需要可用的 OPENAI_API_KEY（strict no-fallback）
OPENAI_API_KEY=your_openai_api_key
EVIDENCE_RAG_INTENT_MODEL=gpt-4.1-mini

### 資料夾
EVIDENCE_RAG_SOURCE_DIR=../rag 文本
EVIDENCE_RAG_WORK_DIR=./evidence_rag_data
EVIDENCE_RAG_PARSER_OUTPUT_DIR=./evidence_parser_output
EVIDENCE_RAG_CLINICAL_RULES_DIR=./clinical_rules
EVIDENCE_RAG_CLINICAL_MANIFEST=./clinical_rules/release_manifest.json

### 規則來源：json 或 api
EVIDENCE_RAG_CLINICAL_RULE_SOURCE=json
# EVIDENCE_RAG_CLINICAL_RULE_SOURCE=api
# EVIDENCE_RAG_CLINICAL_RULE_API_URL=http://127.0.0.1:8099/clinical_rules_bundle.json
# EVIDENCE_RAG_CLINICAL_RULE_API_TIMEOUT_SEC=8
# EVIDENCE_RAG_CLINICAL_RULE_API_POLL_INTERVAL_SEC=30
# EVIDENCE_RAG_CLINICAL_RULE_API_TOKEN=

### 推薦先用 pypdf；有需要再切 mineru
EVIDENCE_RAG_PDF_BACKEND=pypdf
EVIDENCE_RAG_ENABLE_VISION_FALLBACK=true
