# ─── ChatICU Backend — Environment Variables ───────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# ── MUST-CHANGE before production (fail-closed guards enforce these) ──
#   JWT_SECRET          — min 32 chars; app refuses to start without it
#   POSTGRES_PASSWORD   — strong random password
#   SEED_DEFAULT_PASSWORD — must meet password policy (12+ chars, mixed case, digit, special)
# ─────────────────────────────────────────────────────────────────────

# Application
APP_NAME=ChatICU API
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://chaticu:CHANGE_ME@localhost:5432/chaticu
DATA_SOURCE_MODE=db
# DATAMOCK_DIR is optional. Leave empty to auto-detect:
# 1) /datamock (container), 2) <repo>/datamock (local)
DATAMOCK_DIR=
POSTGRES_DB=chaticu
POSTGRES_USER=chaticu
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=1
SESSION_IDLE_TIMEOUT_MINUTES=30

# Password Policy
# MIN_PASSWORD_LENGTH=12
# PASSWORD_EXPIRY_DAYS=90
# PASSWORD_HISTORY_COUNT=5
# RESET_TOKEN_EXPIRE_MINUTES=30

# Account Lockout
# MAX_LOGIN_ATTEMPTS=5
# LOCKOUT_SECONDS=900

# CORS — Production: set to your actual domain(s), e.g. ["https://chaticu.hospital.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:4173","http://localhost:4174","http://localhost:5173","http://localhost:5174","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:4173","http://127.0.0.1:4174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Rate Limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=60/minute

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-5
# LLM_RECENT_MSG_WINDOW=10
# LLM_COMPRESS_THRESHOLD=20
# Optional audit artifact capture for provider raw payloads (disabled by default)
# LLM_AUDIT_CAPTURE_RAW=false
# LLM_AUDIT_CAPTURE_DIR=reports/operations/llm_raw_capture
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embedding Cache (Redis-backed, avoids repeated OpenAI API calls)
# EMBEDDING_CACHE_ENABLED=true
# EMBEDDING_CACHE_TTL_SECONDS=604800

# Reranker — "cohere" (fast, dedicated) or "llm" (GPT-based fallback)
# RERANKER_PROVIDER=cohere
COHERE_API_KEY=

# Agentic RAG (multi-round LLM-driven retrieval)
# RAG_AGENTIC_ENABLED=false
# RAG_AGENTIC_MAX_ROUNDS=3

# LLM-based Guardrail (augments regex safety checks with LLM analysis)
# GUARDRAIL_LLM_ENABLED=true

# RAG Document Path
RAG_DOCS_PATH=

# Evidence RAG microservice (func/)
# FUNC_API_URL=http://127.0.0.1:8001
# FUNC_API_TIMEOUT=30.0

# Seed Data
SEED_DEFAULT_PASSWORD=

# Alerting (severe error webhook, e.g. Slack/Teams incoming webhook URL)
ALERT_WEBHOOK_URL=
