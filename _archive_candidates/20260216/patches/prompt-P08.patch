@@ -175,6 +183,37 @@ jobs:
       - name: Build frontend
         run: npm run build
 
+  static-integration-guards:
+    runs-on: ubuntu-latest
+
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Block except-pass in production code
+        run: |
+          set -euo pipefail
+          if rg -n --glob '*.py' --glob '*.ts' --glob '*.tsx' --glob '*.js' --glob '*.jsx' 'except\s+[^:]+:\s*pass|except\s*:\s*pass' backend src e2e; then
+            echo "[INTG][CI] forbidden except...pass found"
+            exit 1
+          fi
+
+      - name: Block dangerous CORS origin (0.0.0.0)
+        run: |
+          set -euo pipefail
+          if rg -n --glob '*.py' --glob '*.env*' --glob '*.yml' --glob '*.yaml' 'CORS_ORIGINS.*0\.0\.0\.0|allow_origins.*0\.0\.0\.0' backend .; then
+            echo "[INTG][CI] dangerous CORS origin 0.0.0.0 detected"
+            exit 1
+          fi
+
+      - name: Block suspicious secret patterns in tracked files
+        run: |
+          set -euo pipefail
+          git ls-files > /tmp/tracked_files.txt
+          if xargs rg -n -I --no-messages '(AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----|xox[baprs]-[0-9A-Za-z-]{10,}|AIza[0-9A-Za-z\-_]{35}|sk-[A-Za-z0-9]{20,})' < /tmp/tracked_files.txt; then
+            echo "[INTG][CI] suspicious secret pattern detected in tracked files"
+            exit 1
+          fi
+
   e2e-critical-journey:
     runs-on: ubuntu-latest
     needs: [backend-test, migration-check]
